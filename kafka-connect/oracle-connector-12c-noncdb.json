{
  "_comment": [
    "Production connector template for Oracle 12c NON-CDB (traditional instance).",
    "Non-CDB is the most common deployment for legacy 12c databases.",
    "Verify with: SELECT CDB FROM V$DATABASE; -- must return NO",
    "Run oracle/01_cdc_setup_12c_noncdb.sql before registering this connector.",
    "Replace placeholders: <HOSTNAME>, <SID>, <DOMAIN>, <SCHEMA_LIST>"
  ],

  "name": "oracle-cdc-<DOMAIN>",
  "config": {
    "connector.class": "io.debezium.connector.oracle.OracleConnector",

    "database.hostname": "<HOSTNAME>",
    "database.port": "1521",
    "database.user": "dbzuser",
    "database.password": "${file:/kafka/secrets/oracle-creds.properties:dbzuser.password}",
    "database.dbname": "<SID>",
    "database.connection.adapter": "logminer",

    "topic.prefix": "legacy",

    "table.include.list": "<SCHEMA_LIST>",

    "schema.history.internal.kafka.bootstrap.servers": "kafka:9092",
    "schema.history.internal.kafka.topic": "_legacy_schema_history.<DOMAIN>",
    "schema.history.internal.store.only.captured.tables.ddl": "true",

    "decimal.handling.mode": "double",
    "time.precision.mode": "connect",
    "tombstones.on.delete": "true",
    "lob.enabled": "false",

    "snapshot.mode": "initial",
    "snapshot.isolation.mode": "read_committed",
    "snapshot.fetch.size": "2000",
    "snapshot.locking.mode": "none",

    "log.mining.strategy": "redo_log_catalog",
    "log.mining.batch.size.max": "10000",
    "log.mining.sleep.time.max.ms": "3000",
    "log.mining.transaction.retention.hours": "1",

    "max.batch.size": "2048",
    "max.queue.size": "16384",
    "heartbeat.interval.ms": "10000",

    "errors.tolerance": "none",
    "errors.deadletterqueue.topic.name": "dlq.legacy.<DOMAIN>",
    "errors.deadletterqueue.topic.replication.factor": "3",
    "errors.deadletterqueue.context.headers.enable": "true",

    "key.converter": "io.confluent.connect.avro.AvroConverter",
    "key.converter.schema.registry.url": "http://schema-registry:8081",
    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "http://schema-registry:8081",

    "transforms": "unwrap",
    "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
    "transforms.unwrap.drop.tombstones": "false",
    "transforms.unwrap.delete.handling.mode": "rewrite",
    "transforms.unwrap.add.fields": "op,table,ts_ms,scn"
  }
}
